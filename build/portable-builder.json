{
  "appId": "com.castpark.voidbrowser",
  "productName": "VoidBrowser",
  "directories": {
    "output": "release-single"
  },
  "files": [
    "**/*",
    "!release/**/*",
    "!release-single/**/*",
    "!build/iexpress-stage/**/*",
    "!node_modules/.cache/**/*"
  ],
  "win": {
    "icon": "assets/icon.ico",
    "target": [
      "portable"
    ],
    "signAndEditExecutable": false
  }
}